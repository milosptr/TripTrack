    "expo-linking": "~55.0.14",
    "expo-location": "~55.0.0",
    "expo-maps": "~55.0.0",
    "expo-router": "~55.0.13",
    "expo-sharing": "~55.0.0",
    "expo-splash-screen": "~55.0.19",
    "expo-sqlite": "~55.0.0",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.16",
    "expo-task-manager": "~55.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "date-fns": "^4.1.0",
